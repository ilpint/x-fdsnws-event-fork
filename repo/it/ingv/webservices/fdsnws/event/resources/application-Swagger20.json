    "/event": {
      "put": {
        "tags": [
          "fdsnws-event-1.2-INGV-Extension"
        ],
        "summary": "Event management",
        "description": "Put event Quakeml file into database.",
        "parameters": [
          {
            "name": "filename",
            "in": "query",
            "description": "Filename in format PROVIDER_CODE.xml.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dbname",
            "in": "query",
            "description": "Destination database name",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "upindex",
            "in": "query",
            "description": "Optionally updates indexes",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "requestBody": {
          "description": "File format *QuakeML*",
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/quakeml"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "default": ""
                }
              }
            }
          },
          "204": {
            "description": "Nodata.",
            "content": {}
          },
          "400": {
            "description": "Bad request due to improper specification, unrecognized parameter, duplicate identifier, etc.",
            "content": {}
          },
          "401": {
            "description": "Unauthorized, authentication required.",
            "content": {}
          },
          "403": {
            "description": "Authentication failed or access blocked to restricted data.",
            "content": {}
          },
          "500": {
            "description": "Internal server error.",
            "content": {}
          },
          "503": {
            "description": "Service temporarily unavailable, used in maintenance and error condition.s",
            "content": {}
          }
        },
        "security": [
          {
            "BasicAuth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "fdsnws-event-1.2-INGV-Extension"
        ],
        "summary": "Event management",
        "description": "Delete event Quakeml from database",
        "operationId": "delete-event",
        "parameters": [
          {
            "name": "filename",
            "in": "query",
            "description": "Filename in format PROVIDER_CODE.xml, no other parameters needed",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dbname",
            "in": "query",
            "description": "destination database name",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "provider",
            "in": "query",
            "description": "First part of filename of events to be removed, usually provider string:INGV.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "erase",
            "in": "query",
            "description": "If history is enabled and erase=false (default), the DELETE operation closes the validity interval of the active version without removing historical data. If erase=true, all versions of the event are permanently removed.",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "upindex",
            "in": "query",
            "description": "optionally updates indexes",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "default": "Deleted resource: EXAMPLE_CODE.xml"
                }
              }
            }
          },
          "204": {
            "description": "Nodata.",
            "content": {}
          },
          "400": {
            "description": "Bad request due to improper specification, unrecognized parameter, parameter value out of range, etc.",
            "content": {}
          },
          "401": {
            "description": "Unauthorized, authentication required",
            "content": {}
          },
          "403": {
            "description": "Authentication failed or access blocked to restricted data",
            "content": {}
          },
          "500": {
            "description": "Internal server error",
            "content": {}
          },
          "503": {
            "description": "Service temporarily unavailable, used in maintenance and error conditions",
            "content": {}
          }
        },
        "security": [
          {
            "BasicAuth": []
          }
        ]
      }
    },
    "/settings": {
      "get": {
        "tags": [
          "fdsnws-event-1.2-INGV-Extension"
        ],
        "summary": "Server settings",
        "operationId": "getSettings",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/Settings"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "fdsnws-event-1.2-INGV-Extension"
        ],
        "summary": "Server settings",
        "operationId": "setSettings",
        "requestBody": {
          "description": "Settings XML object, there are no required elements",
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/Settings"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success, new settings applied"
          },
